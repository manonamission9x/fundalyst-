#################################################
# Fundalyst — Environment Template
#
# Copy this file to `.env.local` and fill in real values:
#     cp .env.example .env.local
#
# RULES:
#   - This file (.env.example) is COMMITTED to git. Placeholders ONLY — never real secrets.
#   - Put real secrets in `.env.local` (gitignored, stays on your machine).
#   - Every var here must also be declared in src/lib/env.ts (the only file that reads process.env).
#   - Vars prefixed NEXT_PUBLIC_ are exposed to the browser. Everything else is server-only.
#
# NOTE: Fundalyst is currently a 100% client-side app (see BACKEND.md). All server vars
# below are OPTIONAL scaffolding for the planned backend — the app boots fine without them.
#################################################


#################################################
# Database (server-only)
#################################################
# Postgres connection string: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@localhost:5432/fundalyst


#################################################
# Authentication (server-only)
#################################################
# Generate a secret with:  openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000


#################################################
# Redis / Queue (server-only)
#################################################
REDIS_URL=redis://localhost:6379


#################################################
# AI Providers (server-only)
#################################################
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=


#################################################
# OCR (server-only)
#################################################
MISTRAL_API_KEY=


#################################################
# Cloudflare R2 (server-only)
#################################################
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=


#################################################
# Email (server-only)
#################################################
RESEND_API_KEY=


#################################################
# Monitoring
#################################################
# Server-side DSN (server-only)
SENTRY_DSN=
# Browser DSN — safe to expose to the client
NEXT_PUBLIC_SENTRY_DSN=


#################################################
# App (public — exposed to the browser)
#################################################
NEXT_PUBLIC_APP_URL=http://localhost:3000
