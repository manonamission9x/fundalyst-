# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Windows junk
*.lnk

# dependencies
/node_modules
/.prisma
/generated/prisma
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all real/local secret files...
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
# ...but ALWAYS commit the template (must come after the ignores above)
!.env.example

# vercel
.vercel

# copied build artifacts (from node_modules)
/public/pdf.worker.*

# Windows reserved device names (can appear as build artifacts)
nul
con
prn
aux
lpt[0-9]
com[0-9]

# typescript
*.tsbuildinfo
next-env.d.ts
